{
  "name": "portfolio-lucas-vacis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "preview": "vite preview",
    "test": "npm run test:unit",
    "test:watch": "vitest --config vitest.unit.config.ts",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:component": "vitest run --config vitest.component.config.ts",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:ci": "playwright test --config playwright.config.ts",
    "report:e2e": "tsx scripts/e2e-report.ts",
    "report:e2e:open": "playwright show-report artifacts/playwright/html",
    "report:e2e:custom:open": "npm run report:e2e && start report\\index.html",
    "test:ci": "npm run test:unit && npm run test:component"
  },
  "dependencies": {
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.475.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^2.1.8"
  }
}
